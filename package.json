{
  "name": "freedcamp-mcp",
  "version": "0.1.18",
  "description": "MCP server implementation for Freedcamp task management",
  "type": "module",
  "main": "dist/freedcamp-mcp.js",
  "bin": {
    "freedcamp-mcp": "dist/server.js"
  },
  "scripts": {
    "start": "node dist/server.js",
    "test": "npm run build && node dist/test-harness.js",
    "build": "tsc",
    "postbuild": "chmod +x dist/server.js",
    "dev": "tsc --watch",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
    "lint": "eslint \"src/**/*.ts\" \"*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"*.ts\" --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.4",
    "dotenv": "^16.4.1",
    "node-fetch": "^3.3.2",
    "pino": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@types/node": "^20.11.24",
    "@types/node-fetch": "^2.6.11",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.5",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=17.0.0"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ]
}
